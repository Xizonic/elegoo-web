{
  "name": "elegoo-web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n svc,web -c magenta,cyan \"tsx watch src/server/index.ts\" \"vite\"",
    "dev:web": "vite",
    "dev:service": "tsx watch src/server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "service": "tsx src/server/index.ts",
    "service:check": "tsc --project tsconfig.server.json"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "grammy": "^1.35.0",
    "mqtt": "^5.10.0",
    "ws": "^8.18.0"
  }
}
