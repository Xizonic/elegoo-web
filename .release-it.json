{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}",
    "requireCleanWorkingDir": true,
    "requireUpstream": true,
    "tagArgs": ["--no-sign"]
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          { "type": "feat", "section": "Features" },
          { "type": "fix", "section": "Bug Fixes" },
          { "type": "perf", "section": "Performance" },
          { "type": "refactor", "section": "Refactors" },
          { "type": "docs", "section": "Documentation" },
          { "type": "chore", "hidden": true },
          { "type": "style", "hidden": true },
          { "type": "test", "hidden": true }
        ]
      },
      "infile": "CHANGELOG.md",
      "header": "# Changelog"
    }
  },
  "hooks": {
    "before:init": "pnpm lint && pnpm format:check && pnpm test",
    "after:bump": "pnpm build && docker build -t ghcr.io/runnane/elegoo-web:${version} -t ghcr.io/runnane/elegoo-web:latest .",
    "after:release": "echo \"$GITHUB_TOKEN\" | docker login ghcr.io -u runnane --password-stdin && docker push ghcr.io/runnane/elegoo-web:${version} && docker push ghcr.io/runnane/elegoo-web:latest"
  }
}
