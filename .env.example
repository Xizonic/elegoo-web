# Elegoo CC2 Service Configuration

# Printer connection
PRINTER_IP=172.20.100.236
PRINTER_PASSWORD=123456

# Service port (WebSocket + REST API)
SERVICE_PORT=8088

# Camera (MJPEG stream from printer)
CAMERA_ENABLED=true
# CAMERA_URL=http://172.20.100.236:8080  # defaults to http://<PRINTER_IP>:8080

# Telegram Bot (optional — leave empty to disable)
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your chat ID (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID=

# Notification settings
# Progress update interval in percent (e.g. 25 = notify at 25%, 50%, 75%)
PROGRESS_INTERVAL=25

# ---- AI Monitoring (optional) ----
# Enable AI print monitoring
AI_ENABLED=false

# VLM (Vision Language Model) — OpenAI-compatible API
# Works with OpenAI, Ollama, or any compatible endpoint
AI_VLM_ENABLED=true
AI_VLM_API_KEY=
AI_VLM_BASE_URL=http://172.20.100.9:3000/v1
AI_VLM_MODEL=llava

# Local analysis (frame differencing, no external deps)
AI_LOCAL_ENABLED=true

# Analysis interval in seconds (how often to check camera during print)
AI_INTERVAL=60

# Number of consecutive warnings before triggering an alert
AI_ALERT_THRESHOLD=3

# Cooldown in seconds between alerts
AI_ALERT_COOLDOWN=300
# CLIP model for local analysis (downloaded automatically on first use)
AI_LOCAL_MODEL=Xenova/clip-vit-base-patch32
